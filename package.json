{
  "name": "dbd-callouts-overlay",
  "version": "0.0.1",
  "description": "DBD 桌面地圖 overlay - 把圖片釘在桌面左上角,可調透明度/大小 (Electron + Vue)",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --win",
    "release": "electron-vite build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@fontsource/noto-sans-tc": "^5.2.9",
    "active-win": "^8.2.1",
    "electron-updater": "^6.8.9",
    "tesseract.js": "^7.0.0",
    "uiohook-napi": "^1.5.5",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "sharp": "^0.35.1",
    "vite": "^5.3.0"
  },
  "build": {
    "appId": "com.dbd.mapoverlay",
    "productName": "DBD Callouts Overlay",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "DahisC",
      "repo": "dbd-callouts-overlay"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/maps",
        "to": "maps"
      }
    ]
  }
}
